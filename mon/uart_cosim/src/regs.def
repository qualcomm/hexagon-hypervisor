/* These are 32-bit UART registers */
/* Address, register name, R, W, clock regime, reset state, length, register string, description */

/* RW Registers */
DEF_RW_REG(0x0000, MR1, 1, 1, UART_CLK, 0x0, 32, "MR1", "UART mode register #1")
DEF_RW_REG(0x0004, MR2, 1, 1, UART_CLK, 0x0, 32, "MR2", "UART mode register #2")
DEF_RW_REG(0x0008, CSR, 0, 1, UART_CLK, 0x0, 32, "CSR", "UART clock selection register")
DEF_RW_REG(0x000C, TF, 0, 1, UART_CLK, 0x0, 32, "TF", "UART transmit FIFO register")
DEF_RW_REG(0x0010, CR, 0, 1, UART_CLK, 0x0, 32, "CR", "UART command register")
DEF_RW_REG(0x0014, IMR, 0, 1, UART_CLK, 0x0, 32, "IMR", "UART interrupt mask register")
DEF_RW_REG(0x0018, IPR, 1, 1, UART_CLK, 0x0, 32, "IPR", "UART interrupt programming register")
DEF_RW_REG(0x001C, TFWR, 1, 1, UART_CLK, 0x0, 32, "TFWR", "UART transmit fifo watermark register")
DEF_RW_REG(0x0020, RFWR, 1, 1, UART_CLK, 0x0, 32, "RFWR", "UART receive fifo watermark register")
DEF_RW_REG(0x0024, HCR, 1, 1, UART_CLK, 0x0, 32, "HCR", "UART hunt character register")
DEF_RW_REG(0x0028, MREG, 1, 1, UART_CLK, 0x0, 32, "MREG", "UART M value register")
DEF_RW_REG(0x002C, NREG, 1, 1, UART_CLK, 0x0, 32, "NREG", "UART N value register")
DEF_RW_REG(0x0030, DREG, 1, 1, UART_CLK, 0x0, 32, "DREG", "UART D value register")
DEF_RW_REG(0x0034, MNDREG, 1, 1, UART_CLK, 0x0, 32, "MNDREG", "UART M,N,D extra value register")
DEF_RW_REG(0x0038, IRDA, 0, 1, UART_CLK, 0x0, 32, "IRDA", "UART enable IRDA function register")
DEF_RW_REG(0x003C, SIM_CFG, 0, 1, UART_CLK, 0x0, 32, "SIM_CFG", "UART sim interface register")
DEF_RW_REG(0x0040, MISR_MODE, 1, 1, UART_CLK, 0x0, 32, "MISR_MODE", "UART BLAH register")
DEF_RW_REG(0x0044, MISR_RESET, 1, 1, UART_CLK, 0x0, 32, "MISR_RESET", "UART BLAH register")
DEF_RW_REG(0x0048, MISR_EXPORT, 1, 1, UART_CLK, 0x0, 32, "MISR_EXPORT", "UART BLAH register")
DEF_RW_REG(0x004C, MISR_VAL, 1, 1, UART_CLK, 0x0, 32, "MISR_VAL", "UART BLAH register")
DEF_RW_REG(0x0050, TEST_CTRL, 1, 1, UART_CLK, 0x0, 32, "TEST_CTRL", "UART BLAH register")
DEF_RW_REG(0x0054, TEST_WR_ADDR, 1, 1, UART_CLK, 0x0, 32, "TEST_WR_ADDR", "UART BLAH register")
DEF_RW_REG(0x0058, TEST_WR_DATA, 0, 1, UART_CLK, 0x0, 32, "TEST_WR_DATA", "UART BLAH register")
DEF_RW_REG(0x005C, TEST_RD_ADDR, 1, 1, UART_CLK, 0x0, 32, "TEST_RD_ADDR", "UART BLAH register")


/* R Registers */
DEF_R_REG(0x0008, SR, 1, 0, UART_CLK, 0x0, 32, "SR", "UART status register")
DEF_R_REG(0x000C, RF, 1, 0, UART_CLK, 0x0, 32, "RF", "UART receive FIFO register")
DEF_R_REG(0x0010, MISR, 1, 0, UART_CLK, 0x0, 32, "MISR", "UART masked interrupt status register")
DEF_R_REG(0x0014, ISR, 1, 0, UART_CLK, 0x0, 32, "ISR", "UART BLAH register")
DEF_R_REG(0x0060, TEST_RD_DATA, 1, 0, UART_CLK, 0x0, 32, "TEST_RD_DATA", "UART BLAH register")

/* Register Fields */
/* REG NAME, FIELD NAME, START POS, NBITS, FIELD NAME STRING, DESCRIPTION) */
DEF_REG_FIELD(MR1, AUTO_RFR_LEVEL0, 0, 6, "AUTO_RFR_LEVEL0", "BLAH!")
DEF_REG_FIELD(MR1, CTS_CTL, 6, 1, "CTS_CTL", "BLAH!")
DEF_REG_FIELD(MR1, RX_RDY_CTL, 7, 1, "RX_RDY_CTL", "BLAH!")
DEF_REG_FIELD(MR1, AUTO_RFR_LEVEL1, 8, 10, "AUTO_RFR_LEVEL1", "BLAH!")

DEF_REG_FIELD(MR2, LOOPBACK, 7, 1, "LOOPBACK", "BLAH!")
DEF_REG_FIELD(MR2, ERROR_MODE, 6, 1, "ERROR_MODE", "BLAH!")
DEF_REG_FIELD(MR2, BITS_PER_CHAR, 4, 2, "BITS_PER_CHAR", "BLAH!")
DEF_REG_FIELD(MR2, STOP_BIT_LEN, 2, 2, "STOP_BIT_LEN", "BLAH!")
DEF_REG_FIELD(MR2, PARITY_MODE, 0, 2, "PARITY_MODE", "BLAH!")

DEF_REG_FIELD(TFWR, TFW, 0, 18, "TFW", "BLAH!")

DEF_REG_FIELD(RFWR, RFW, 0, 18, "RFW", "BLAH!")

DEF_REG_FIELD(IMR, TXLEV, 0, 1, "TXLEV", "BLAH!")
DEF_REG_FIELD(IMR, RXLEV, 4, 1, "RXLEV", "BLAH!")

DEF_REG_FIELD(CR, CHANNEL_COMMAND, 4, 5, "CHANNEL_COMMAND", "BLAH!")
DEF_REG_FIELD(CR, UART_TX_DISABLE, 3, 1, "UART_TX_DISABLE", "BLAH!")
DEF_REG_FIELD(CR, UART_TX_EN, 2, 1, "UART_TX_EN", "BLAH!")
DEF_REG_FIELD(CR, UART_RX_DISABLE, 1, 1, "UART_RX_DISABLE", "BLAH!")
DEF_REG_FIELD(CR, UART_RX_EN, 0, 1, "UART_RX_EN", "BLAH!")

DEF_REG_FIELD(ISR, TXLEV, 0, 1, "TXLEV", "BLAH!")
DEF_REG_FIELD(ISR, RXLEV, 4, 1, "RXLEV", "BLAH!")

DEF_REG_FIELD(SR, HUNT_CHAR, 7, 1, "HUNT_CHAR", "BLAH!")
DEF_REG_FIELD(SR, TXRDY, 2, 1, "TXRDY", "BLAH!")
DEF_REG_FIELD(SR, RXFULL, 1, 1, "RXFULL", "BLAH!")
DEF_REG_FIELD(SR, RXRDY, 0, 1, "RXRDY", "BLAH!")

