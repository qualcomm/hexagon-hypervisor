From 61f1a6e071f32301ece64d7929d7b46fc0667804 Mon Sep 17 00:00:00 2001
From: Erich Plondke <erich@qualcomm.com>
Date: Thu, 8 Aug 2013 10:54:40 -0500
Subject: [PATCH 1/8] V5 has bigger caches... probably need to check these
 bits too though

---
 kernel/util/cache/cache.ref.S |    9 ++++++++-
 1 files changed, 8 insertions(+), 1 deletions(-)

diff --git a/kernel/util/cache/cache.ref.S b/kernel/util/cache/cache.ref.S
index 6a4c0de..4e1fbc8 100644
--- a/kernel/util/cache/cache.ref.S
+++ b/kernel/util/cache/cache.ref.S
@@ -9,13 +9,20 @@
 #define DC_WAYS 16
 #define IC_SETS (32*1024/32/8)
 #define IC_WAYS 8
-#else
+#elif ARCHV == 4
 #define L2_SETS (256*1024/32/4)
 #define L2_WAYS 4
 #define DC_SETS (16*1024/32/8)
 #define DC_WAYS 8
 #define IC_SETS (16*1024/32/8)
 #define IC_WAYS 8
+#elif ARCHV >= 5
+#define L2_SETS (256*1024/32/4)
+#define L2_WAYS 4
+#define DC_SETS (32*1024/32/8)
+#define DC_WAYS 8
+#define IC_SETS (32*1024/32/8)
+#define IC_WAYS 8
 #endif
 
 FUNC_START H2K_cache_l2_cleaninv .text.misc.cache .p2align 4
-- 
