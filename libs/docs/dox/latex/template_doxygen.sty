\usepackage[T1]{fontenc}

%Redefine Chapter headers
\def\@chapter[#1]#2{\ifnum \c@secnumdepth >\m@ne
                       \if@mainmatter
                         \refstepcounter{chapter}%
                         \typeout{\@chapapp\space\thechapter.}%
                         \addcontentsline{toc}{chapter}%
                                   {\protect\numberline{\thechapter}#1}%
                       \else
                         \addcontentsline{toc}{chapter}{#1}%
                       \fi
                    \else
                      \addcontentsline{toc}{chapter}{#1}%
                    \fi
                    \chaptermark{#1}%
                    \addtocontents{lof}{\protect\addvspace{1\p@}}%
                    \addtocontents{lot}{\protect\addvspace{1\p@}}%
                    \if@twocolumn
                      \@topnewpage[\@makenchapterhead{#2}]%
                    \else
                      \@makenchapterhead{#2}%
                      \@afterheading
                    \fi}
\def\@makenchapterhead#1{%  %this group is executed!
  \vspace*{0\p@}%
  {\parindent \z@ \flushleft \Huge %changed from tiny to Huge - had no affect
    \ifnum \c@secnumdepth >\m@ne
      \if@mainmatter
        \Huge\bfseries\sf \thechapter \hspace{.321in} %- changed tiny to Huge - changed Chapter name!
      \fi
    \fi
    \interlinepenalty\@M
    \Huge \bfseries\sf #1 \par \nobreak \vspace{-.3in} %changed tiny to Huge - changed title name!
    \color{blue} \rule{6.5in}{.018in} \\
    \vspace{.8in}
    \vskip 1\p@
  }}

\def\@schapter#1{\if@twocolumn
                   \@topnewpage[\@makeschapterhead{#1}]%
                 \else
                   \@makeschapterhead{#1}%
                   \@afterheading
                 \fi}
\def\@makeschapterhead#1{%  %not executing this group
  \vspace*{1\p@}%
  {\parindent \z@ \raggedright
    \tiny
    \interlinepenalty\@M
    \sf \Huge \bfseries  #1\par\nobreak
    \vskip 1\p@
    \thispagestyle{fancy}
  }}
%End redefine Chapter Headers

