# Dear emacs, this is a -*- Makefile -*-

ifndef MAKE_INC_CONFIG
MAKE_INC_CONFIG := 1

##### default configuration

# Build with multi-core support
MULTICORE := 1

# This should never ever need to change
export H2K_LINK_ADDR ?= 0xff000000

# Where we load kernel
export H2K_LOAD_ADDR ?= 0x0

# Don't need any heap or stack space, but 0 means use default, which we need for unit tests.

export H2K_HEAP_SIZE ?= 0x1  # not 0 to avoid using DEFAULT_HEAP_SIZE

export H2K_STACK_SIZE ?= 0x1  # not 0 to avoid using DEFAULT_STACK_SIZE

export H2K_ALLOC_HEAP_SIZE ?= 0x20000 # in words

export H2K_KERNEL_PGSIZE ?= 3  # 256K

# Page offset for smallest page size
export H2K_KERNEL_ADDRBITS ?= 12

# Where we put .start section.  Must be after H2K_LOAD_ADDR; more specifically
# after bootvm_start
export H2K_GUEST_START ?= 0x02000000

# Highest page accessible to guest, inclusive
export H2K_GUEST_END ?= 0xfe000000

# Multicore bootmem size
export H2K_BOOTMEM_SIZE ?= 0x40000000


##### build controls
export USE_PKW ?= 1

ifeq ($(H2DIR),)
export H2DIR := $(CURDIR)
endif

ifeq ($(KERNELPATH),)
export KERNELPATH := $(H2DIR)/kernel
endif

ARCHV_LIST ?= 68 73 81
VARIANTS   ?= opt ref opt_si

TARGET ?= opt
ARCHV ?= 81

ifneq ($(findstring $(ARCHV),65,66,67),)
override ARCHV := 65
endif

ifneq ($(findstring $(ARCHV),68,71),)
override ARCHV := 68
endif

ifneq ($(findstring $(ARCHV),73,75,77,79),)
override ARCHV := 73
endif

ifneq ($(findstring $(ARCHV),81,83,85,87,89,91),)
override ARCHV := 81
endif

ifeq ($(TARGET), 8960)
T := opt
ARCHV := 4
H2K_KERNEL_PGSIZE ?= 3
H2K_ALLOC_HEAP_SIZE ?= 0xb000
export H2K_EXTRA_CFLAGS += -DCOUNT_TLB_EVENTS
endif

ifeq ($(TARGET), 8974)
T := opt
ARCHV := 5
H2K_KERNEL_PGSIZE ?= 3
H2K_ALLOC_HEAP_SIZE ?= 0xb000
export H2K_EXTRA_CFLAGS += -DCOUNT_TLB_EVENTS
export USE_TCM ?= 1
endif

ifeq ($(TARGET), zebu_v60)
T := opt
ARCHV := 60
H2K_KERNEL_PGSIZE ?= 3
H2K_ALLOC_HEAP_SIZE ?= 0xb000
export H2K_EXTRA_CFLAGS += -DCOUNT_TLB_EVENTS
#export USE_TCM ?= 1
endif

ifeq ($(TARGET), zebu_v65)
T := opt
ARCHV := 65
H2K_KERNEL_PGSIZE ?= 3
H2K_ALLOC_HEAP_SIZE ?= 0xb000
export H2K_EXTRA_CFLAGS += -DCOUNT_TLB_EVENTS
#export USE_TCM ?= 1
endif

ifeq ($(TARGET), opt)
T := opt
#OPT_JFLAG :=
endif

ifeq ($(TARGET), opt_cov)
T := opt
OPT_JFLAG :=
export OPT_ADD := $(OPTIMIZE_COV)
endif

ifeq ($(TARGET), llvm_cov)
T := opt
OPT_JFLAG :=
export EN_LLVM_COV := 1
endif

ifeq ($(TARGET), opt_snap)
T := opt
export H2K_LOAD_ADDR=0x00400000 
export H2K_EXTRA_CFLAGS+=-DNMI_STOP
endif

ifeq ($(TARGET), opt_tiny_snap)
override ARCHV := 65  # because some things call make with ARCHV=66t
T := opt
export TINY_CORE=1
export H2K_LOAD_ADDR=0x00400000
export H2K_EXTRA_CFLAGS+=-DNMI_STOP
endif

ifeq ($(TARGET), ref)
T := ref
endif

ifeq ($(TARGET), ref_cov)
T := ref
REF_JFLAG :=
export OPT_ADD := $(OPTIMIZE_COV)
endif

ifeq ($(TARGET), debug)
T := ref
REF_JFLAG :=
export OPTIMIZE := $(OPTIMIZE_DEBUG)
endif

ifeq ($(TARGET), opt_si)
T := opt
export H2K_LOAD_ADDR=0x84c00000
export H2K_GUEST_START=0x87000000
export NULL_ANGEL_TRAP=1
export MAGIC_ANGEL=--magic_angel
endif

# FIXME: Remove when cluster sched ported to opt
export OMIT_OPT=dosched resched

# If invoking 'make ref', 'make ref_cov', or 'make debug' directly without
# setting TARGET=ref, still use the ref artifact directory.
ifneq ($(filter ref ref_cov debug,$(MAKECMDGOALS)),)
T := ref
endif

# Derive per-ARCHV/TARGET install path.  T is set above by TARGET ifeq blocks.
INSTALLPATH := $(H2DIR)/artifacts/v$(ARCHV)/$(TARGET)/install
export INSTALLPATH
export T

# TESTOUT: per-variant summary file; lives in the artifact dir so parallel
# ARCHV builds each get their own copy with no conflicts.
TESTOUT ?= $(INSTALLPATH)/test.out

##### utils

printvar-%  : ; @echo $* = $($*)

endif
