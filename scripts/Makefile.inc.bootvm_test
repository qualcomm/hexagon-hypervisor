ifeq ($(TARGET), rtl)
CRT0_S := $(INSTALLPATH)/src/min_crt0.S
CRT0_O := min_crt0.o
NOSTARTFILES := -nostartfiles
CFLAGS+= -DRTL
else
CFLAGS+= -DDEBUG
endif

BOOTVM_PROG := .$(EXEC)
BOOTVM_LDFLAGS = $(NOSTARTFILES) -L$(INSTALLPATH)/lib -moslib=h2 -Qunused-arguments

all: $(BOOTVM_PROG)

include $(H2DIR)/scripts/Makefile.inc.bootvm

$(BOOTVM_IMAGE): LDFLAGS = $(BOOTVM_LDFLAGS)
$(BOOTVM_PROG_TMP): LDFLAGS = $(BOOTVM_LDFLAGS)
$(BOOTVM_PROG): LDFLAGS = $(BOOTVM_LDFLAGS)

$(BOOTVM_IMAGE): $(OBJS) $(CRT0_O) $(BOOTVM_IMAGE_DEPS)
	${CC} $(LDFLAGS) $(CFLAGS) $(BOOTVM_IMAGE_CFLAGS) -Wl,--defsym=HEAP_SIZE=0x10000 -Wl,--defsym=STACK_SIZE=0x1000 -Wl,--defsym=__h2_thread_stop_hook__=0xfffffff0 -o $@ $(OBJS) $(CRT0_O) $(BOOTVM_ENTRY_O) 2>&1 | perl -pe 's/.*Symbol.*__h2_.*_hook__.*is defined in both linker script and input file.*//';

# Suppress warnings about changing the recipe for $(EXEC)
$(EXEC) : private CC = true
test.log: | symlink
test.objdump: | symlink

.PHONY: symlink
symlink: $(BOOTVM_PROG)
	if [ ! -f $(EXEC) ]; then ln -s $(BOOTVM_PROG) $(EXEC); fi;
