}

% is used for parameters within a detailed function description
\newenvironment{DoxyParamCaption}{%
  \renewcommand{\item}[2][]{##1 {\em ##2}}%
  }{%
}

% Used by return value lists
\newenvironment{DoxyRetVals}[1]{%
