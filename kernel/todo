Priority Inheritance:

	futex_wait(void *, u32_t expected, threadid owner_tid)

owner_context = tid_to_context(tid)
If (owner_context) {
	if (in_ready_queue(owner_context)) {
		/* Switch to it immediately */
		ready_remove(owner_context);
		owner_context->prio = min(owner_context->prio,me->prio)
		runlist_push(owner_context);
		switch(me,owner_context);
	} else {
		/* In runlist or blocked */
		owner_context->new_prio = min(owner_context->prio,me->prio);
	}


	futex_resume

Sets me->prio back to me->baseprio if different (always? Sometimes?)

