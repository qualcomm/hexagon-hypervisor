# Dear emacs, this is a -*- Makefile -*-

################################################################################
#  Test makefile doesn't share above the test dir
################################################################################

#  symbolic link to h2 project directory
#h2: 
#	-ln -s ${H2DIR} $@

################################################################################
#  Tool stuff
################################################################################

default-target: all

ifneq (,$(Q6VERSION))
ARCHV=$(subst v,,$(Q6VERSION))
endif

ifeq ($(ARCHV),)
ARCHV = 4
endif

ifeq ($(MODEL),)
   MODEL = ref
   MODELSTR = ${MODEL}
else
   ifeq ($(MODEL),ref)
      MODELSTR = ${MODEL}
   else
      MODELSTR = ${MODEL}_v${ARCHV}
   endif
endif

ifeq ($(H2K_LINK_ADDR),)
export H2K_LINK_ADDR = 0xff000000
endif

ifeq ($(H2K_HEAP_SIZE),)
H2K_HEAP_SIZE = 0x100000
endif

ARCH=qdsp6
RUN=${ARCH}-sim
CC=${ARCH}-gcc
AS=${ARCH}-as
LD=${ARCH}-ld
AR=${ARCH}-ar
OBJDUMP=${ARCH}-objdump
GMON_MERGE=${ARCH}-gmon-merge
COV=${ARCH}-cov
PYTHON=python

BUSPENALTY=
TIMING=
include /prj/dsp/qdsp6/arch/make/simf.inc

################################################################################
#  Rules for building the kernel if necessary; should be built way before any
#  batch jobs are run else they will maul each other in the animal farm.
#
#  Actually, I've broken the dependency between the libs and the executable so 
#  they will never actually try to build the libs; if you need the libs, you 
#  should 'make libs' before you run.
################################################################################

LIBH2_DIR=${H2DIR}/install/lib
LIBH2=${LIBH2_DIR}/libh2.a

LIBH2KERNEL_DIR=${H2DIR}/install/lib
LIBH2KERNEL=${LIBH2KERNEL_DIR}/libh2kernel.a
LIBH2CHECK=${H2DIR}/kernel/libh2check.a

#  Needs to have the tools already in path...
#SIMPATH=/pkg/qct/software/hexagon/releases/tools/1.2/qc/bin
#TOOLPATH=/pkg/qct/software/hexagon/releases/tools/1.2/gnu/bin
#COVPATH=/pkg/qct/software/hexagon/releases/tools/1.2/examples/utils/bin

${LIBH2KERNEL}: ${H2DIR}/install

#check is always in ref/
${LIBH2CHECK}: ${H2DIR}/install
	+cd ${H2DIR}/kernel;\
	$(MAKE) check DEBUG=0 ARCHV=${ARCHV};\
	cp build/ref/libh2check.a ../install/lib

${LIBH2}:  ${H2DIR}/install

${H2DIR}/install:
	cd ${H2DIR};\
	+$(MAKE) ${MODEL} ARCHV=${ARCHV}

${BOOTER}: ${H2DIR}/install


# (_8^(|)  d'oh!
#  Need to tell people to stop using this one and use 'prepare'
libs: ${LIBH2} ${LIBH2CHECK} ${LIBH2KERNEL} ${BOOTER}

prepare: ${LIBH2} ${LIBH2CHECK} ${LIBH2KERNEL} ${BOOTER}

clean_libs:
	cd ${H2DIR};\
	rm -rf install; $(MAKE) clean

clean_top:
	rm -Rf test.cov_fns cov.txt report.html make.log


################################################################################
#  Standard compilation flags
################################################################################

OPTIMIZE := -O1

ifdef BOOT
BOOTER=${H2DIR}/install/bin/booter
CFLAGS +=${OSLIB} $(OPTIMIZE) -mv${ARCHV} -DARCHV=${ARCHV} -Wall -g
LDFLAGS += -Wl,--section-start=.start=0x00010000
else
CFLAGS +=${OSLIB} $(OPTIMIZE) -mv${ARCHV} -DARCHV=${ARCHV} -DH2K_LINK_ADDR=$(H2K_LINK_ADDR) -Wall -g -Wl,--section-start=.start=$(H2K_LINK_ADDR) -Wl,--defsym=HEAP_SIZE=$(H2K_HEAP_SIZE)
endif

ifdef STANDALONE
CFLAGS += -I ${H2DIR}/kernel/include
LDFLAGS += -lh2kernel -lh2 -lh2check -L ${H2DIR}/install/lib -Wl,--section-start=.start=$(H2K_LINK_ADDR) -Wl,--defsym=HEAP_SIZE=$(H2K_HEAP_SIZE)
ASFLAGS +=${OSLIB} -mv${ARCHV} -DARCHV=${ARCHV} -Wall -I ${H2DIR}/kernel/include
else
OSLIB=-moslib=h2
ifdef BOOT
LDFLAGS +=${OSLIB} -L ${H2DIR}/install/lib
else
LDFLAGS +=${OSLIB} -lh2kernel -lh2 -lh2check -L ${H2DIR}/install/lib -Wl,--section-start=.start=$(H2K_LINK_ADDR) -Wl,--defsym=HEAP_SIZE=$(H2K_HEAP_SIZE)
endif
CFLAGS += -I ${H2DIR}/install/include
ASFLAGS +=${OSLIB} -mv${ARCHV} -DARCHV=${ARCHV} -Wall -I ${H2DIR}/install/include
endif
LDFLAGS+= -mv${ARCHV}
#  Turn on call() support for assertion checking
#CFLAGS += -DDEBUG
#  Optimization level needs to match whatever the kernel is compiled with.

ifdef INC_KERNEL
CFLAGS += -I${H2DIR}/kernel/include
ASFLAGS += -I${H2DIR}/kernel/include
endif

ifdef DEBUG
CFLAGS += -DDEBUG
endif

################################################################################
#  Convenience shortcuts
################################################################################

ifdef SUBDIRS

################################################################################
#  Recursive subdirectory traversal
################################################################################

#SUBDIR_MAKE=+for SUBDIR in ${SUBDIRS}; do\
#	$(MAKE) -C $$SUBDIR $(MAKECMDGOALS) TEST=$$SUBDIR; TSTAT=$$?; \
#        if [ $$TSTAT -ne 0 ]; then STAT=$$TSTAT; fi; \
#	done; exit $$STAT

#SUBDIR_TARGETS=clean all

#${SUBDIR_TARGETS}:
#	${SUBDIR_MAKE}

#  Uh...  don't run this unless all the tests are run for now.
cov.txt:
	find ./kernel ./libs -name "cov.txt" | python ${H2DIR}/scripts/merge_cov.py > $@

cov.rpt: cov.txt
	${H2DIR}/scripts/cov_rpt_tool > $@

#  every "subdir" needs to have a results.txt in it for this to run properly.
#  if no results.txt, FAIL
#  if results.txt is empty, FAIL
#  
#	      grep -A 1 FAIL $$SUBDIR/test.log >> report.html; \
#	      echo FAIL:  no pass signature >> report.html;\

report.html:
	@echo "<html><body><table>" > report.html;\
	for SUBDIR in ${SUBDIRS}; do\
	   echo "<tr><td> $$SUBDIR</td>" >> report.html;\
	   if [ ! -s $$SUBDIR/results.txt ]; then\
	      echo '<td><font style="background-color: red;">' >> report.html; \
	      echo 'Missing results.txt, that should not be!' >> report.html; \
	      echo '</font></td>' >> report.html; \
	   else\
	      grep "TEST PASSED" $$SUBDIR/results.txt > /dev/null; \
	      if [ $$? -eq 0 ]; then \
	         echo '<td>' >> report.html; \
		 cat $$SUBDIR/results.txt >> report.html; \
		 echo '</td>' >> report.html; \
	      else \
	         echo '<td><font style="background-color: red;">' >> report.html; \
		 cat $$SUBDIR/results.txt >> report.html; \
		 echo '</font></td>' >> report.html; \
	      fi; \
	   fi; \
	   cat $$SUBDIR/make.log >> make.log;\
	done;\
	echo "</table></body></html>" >> report.html;

.PHONY: check

check-fail:
	@for SUBDIR in ${SUBDIRS}; do\
	   echo -n "$$SUBDIR: "; \
	   if [ ! -s $$SUBDIR/results.txt ]; then\
	      echo FAIL - Empty/No results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "ERROR" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - ERROR detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "FAIL" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - FAIL detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "TEST PASSED" $$SUBDIR/results.txt;\
	   if [ $$? -ne 0 ]; then\
	      echo FAIL - No PASS detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   echo; \
	done

check:
	@for SUBDIR in ${SUBDIRS}; do\
	   echo -n "$$SUBDIR: "; \
	   if [ ! -s $$SUBDIR/results.txt ]; then\
	      echo FAIL - Empty/No results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   grep "ERROR" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - ERROR detected in results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   grep "FAIL" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - FAIL detected in results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   grep "TEST PASSED" $$SUBDIR/results.txt;\
	   if [ $$? -ne 0 ]; then\
	      echo FAIL - No PASS detected in results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   echo; \
	done


else

DUMP:= $(patsubst %.elf,%.objdump,$(EXEC))

################################################################################
#  These are for actual terminal directories
################################################################################
%.objdump: %.elf
	${OBJDUMP} -D ${@:.objdump=.elf} ${BOOTER} > $@; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\ndisassm fail"|tee test.log; exit 1; fi

ifdef PYTHON_GENERATOR_SCRIPT
${PYTHON_GENERATED_FILES}: ${PYTHON_GENERATOR_SCRIPT}
	${PYTHON} $<; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; exit 1; fi
endif

%.o: %.c ${PYTHON_GENERATED_FILES}
	${CC} ${CFLAGS} -c -o $@ $<; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; exit 1; fi

%.o: %.S ${PYTHON_GENERATED_FILES}
	${CC} ${ASFLAGS} -c -o $@ $<; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; exit 1; fi

${EXEC}: ${OBJS}
	${CC} -o $@ ${OBJS} ${LDFLAGS}; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; exit 1; fi

ignore_fns: ${OBJS}
	${H2DIR}/scripts/gen_ignore_fns.pl ${OBJS} > $@

# each test has a max of 60 seconds!
test.log: ${EXEC}
	ulimit -t 60 && ${RUN} ${SIMF} --profile -- ${BOOTER} ${EXEC} | tee $@; \
	CODE=$${PIPESTATUS[0]}; \
	if [ "$$CODE" -eq 137 ]; then \
	   echo -e "\nERROR: ${TEST}: probably ulimit" >> $@; \
	fi;

# Coverage stuff -- single testcase

gmon.out: test.log
	${GMON_MERGE} -o gmon.out gmon.t_*

COVFILES=cov.txt
GMON_FILES=gmon.out gmon.t_0 gmon.t_1 gmon.t_2 gmon.t_3 gmon.t_4 gmon.t_5

${COVFILES}: ${DUMP} gmon.out ignore_fns
	${COV} -F -d ${DUMP} -o cov.txt gmon.out; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\ncoverage fail"; exit 1; fi

CLEANUP=${PYTHON_GENERATED_FILES} ${OBJS} ${EXEC} ${COVFILES} ${GMON_FILES} ${DUMP} make.log test.log results.txt h2
CLEANUP += stats.txt stats_help.txt ihist.txt prof.txt ignore_fns

clean:
	rm -rf ${CLEANUP}

#  Pretty much a binary yes/no if the test passed or failed.
results.txt: test.log
	@grep "TEST PASSED" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 0; fi; \
	grep -A 1 "ERROR" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 0; fi; \
	grep -A 1 "FAIL" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 0; fi; \
	if [ ! -s test.log ]; then \
	  echo "FAIL - Test log empty" > $@; \
	  exit 0; \
	fi; \
	echo "NO PASS/FAIL/ERROR in log" > $@; \
	true;

all: results.txt ${COVFILES}
tst: results.txt


endif
