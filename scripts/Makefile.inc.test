# Dear emacs, this is a -*- Makefile -*-

ifndef MAKE_INC_TEST
MAKE_INC_TEST := 1

################################################################################
#  Test makefile doesn't share above the test dir
################################################################################

#  symbolic link to h2 project directory
#h2: 
#	-ln -s ${H2DIR} $@

################################################################################
#  Tool stuff
################################################################################

default-target: all

include $(H2DIR)/scripts/Makefile.inc.tools

export PKW_VERSIONS := hexagon-tools=$(TOOLS_FLAVOR_KERNEL) arch=$(ARCH_FLAVOR)


ifeq ($(MODEL),)
   MODEL = ref
   MODELSTR = ${MODEL}
else
   ifeq ($(MODEL),ref)
      MODELSTR = ${MODEL}
   else
      MODELSTR = ${MODEL}_v${ARCHV}
   endif
endif

H2K_HEAP_SIZE = 0x00010000

ifeq ($(INSTALLPATH),)
export INSTALLPATH := ${INSTALLPATH}
endif

ifeq ($(KERNELPATH),)
export KERNELPATH := $(H2DIR)/kernel
endif


include $(H2DIR)/scripts/Makefile.inc.config
include $(H2DIR)/scripts/Makefile.inc.version
include $(H2DIR)/scripts/Makefile.inc.constants
include $(H2DIR)/scripts/Makefile.inc.tools

PYTHON=python

BUSPENALTY=
TIMING=
#Till I figure out something better, here is that file
RUN ?= hexagon-sim

TIMING ?= --timing

BUSPENALTY ?= --buspenalty 50

ULIMIT ?= 300

_BASIC_SIMF=$(TIMING) --simulated_returnval $(BUSPENALTY)

ifeq (hexagon-sim, $(notdir $(firstword ${RUN})))
SIMF=${_BASIC_SIMF}
endif

ifeq (hexagon-sim, $(notdir $(firstword ${RUN})))
SIMF=${_BASIC_SIMF}
endif

################################################################################
#  Rules for building the kernel if necessary; should be built way before any
#  batch jobs are run else they will maul each other in the animal farm.
#
#  Actually, I've broken the dependency between the libs and the executable so 
#  they will never actually try to build the libs; if you need the libs, you 
#  should 'make libs' before you run.
################################################################################

LIBH2_DIR=${INSTALLPATH}/lib
LIBH2=${LIBH2_DIR}/libh2.a

LIBH2KERNEL_DIR=${INSTALLPATH}/lib
LIBH2KERNEL=${LIBH2KERNEL_DIR}/libh2kernel.a
LIBH2CHECK=${H2DIR}/kernel/libh2check.a

#  Needs to have the tools already in path...
#SIMPATH=/pkg/qct/software/hexagon/releases/tools/1.2/qc/bin
#TOOLPATH=/pkg/qct/software/hexagon/releases/tools/1.2/gnu/bin
#COVPATH=/pkg/qct/software/hexagon/releases/tools/1.2/examples/utils/bin

${LIBH2KERNEL}: ${INSTALLPATH}

#check is always in ref/
${LIBH2CHECK}: ${INSTALLPATH}
	+cd ${H2DIR}/kernel;\
	$(MAKE) check DEBUG=0 ARCHV=${ARCHV};\
	cp build/ref/libh2check.a ${INSTALLPATH}/lib

${LIBH2}:  ${INSTALLPATH}

${INSTALLPATH}:
	cd ${H2DIR};\
	+$(MAKE) ${MODEL} ARCHV=${ARCHV}

${BOOTER}: ${INSTALLPATH}


# (_8^(|)  d'oh!
#  Need to tell people to stop using this one and use 'prepare'
libs: ${LIBH2} ${LIBH2CHECK} ${LIBH2KERNEL} ${BOOTER}

prepare: ${LIBH2} ${LIBH2CHECK} ${LIBH2KERNEL} ${BOOTER}

clean_libs:
	cd ${H2DIR};\
	rm -rf install; $(MAKE) clean

clean_top:
	rm -Rf test.cov_fns cov.txt report.html qurt_report.html make.log


################################################################################
#  Standard compilation flags
################################################################################

OPTIMIZE := -O1

# For tests are linked in monitor space we don't have __bootvm_entry.  Instead,
# go directly to qdsp6_pre_main (i.e. the old way).  Tests that use booter are
# unaffected by this, because booter has already been built.

# FIXME: Remove H2K_LOAD_ADDR=$(H2K_LINK_ADDR) when tests are no longer in
# monitor space

KERNEL_INCLUDES := -I ${H2DIR}/kernel/include -I ${H2DIR}/libs/h2/common

LDFLAGS += -Wl,--defsym=__bootvm_entry=qdsp6_pre_main -Wl,--defsym=H2K_KERNEL_NPAGES=$(H2K_KERNEL_NPAGES) -Wl,--defsym=H2K_LOAD_ADDR=$(H2K_LINK_ADDR) -Wl,-e=start

ifdef BOOT
BOOTER=${INSTALLPATH}/bin/booter
CFLAGS += $(OPTIMIZE) -mv${TOOLARCH} -DARCHV=${ARCHV} -Wall -g
LDFLAGS += -Wl,--section-start=.start=$(H2K_GUEST_START)
else
CFLAGS += $(OPTIMIZE) -mv${TOOLARCH} -DARCHV=${ARCHV} -DH2K_LINK_ADDR=$(H2K_LINK_ADDR) -Wall -g
ifndef STANDALONE

# 0xfffffff0 means don't call the hook
LDFLAGS += -Wl,--defsym=__h2_handle_errors_hook__=0xfffffff0 -Wl,--defsym=__h2_thread_stop_hook__=0xfffffff0 -Wl,--section-start=.start=$(H2K_LINK_ADDR) -Wl,--defsym=HEAP_SIZE=$(H2K_HEAP_SIZE) -Wl,--defsym=H2K_ALLOC_HEAP_SIZE=$(H2K_ALLOC_HEAP_SIZE)
endif
endif

ifdef STANDALONE
CFLAGS += @${H2DIR}/kernel/build/flags/abi @${H2DIR}/kernel/build/flags/testabi $(KERNEL_INCLUDES) -DH2K_GIT_COMMIT=$(H2K_GIT_COMMIT) -DH2K_ALLOC_HEAP_SIZE=$(H2K_ALLOC_HEAP_SIZE)
LDFLAGS += -Wl,--defsym=__h2_handle_errors_hook__=0xfffffff0 -Wl,--defsym=__h2_thread_stop_hook__=0xfffffff0 -lh2kernel -lh2 -lh2check -L ${INSTALLPATH}/lib
ASFLAGS += -mv${TOOLARCH} -DARCHV=${ARCHV} -Wall $(KERNEL_INCLUDES)

else # non-STANDALONE
OSLIB=-moslib=h2

ifdef BOOT # use booter
LDFLAGS +=${OSLIB} -L ${INSTALLPATH}/lib

else # run in place of booter
LDFLAGS +=${OSLIB} -lh2kernel -lh2 -lh2check -L ${INSTALLPATH}/lib
endif # BOOT

CFLAGS += -I ${INSTALLPATH}/include
ASFLAGS += -mv${TOOLARCH} -DARCHV=${ARCHV} -Wall -I ${INSTALLPATH}/include
endif #STANDALONE
LDFLAGS+= -mv${TOOLARCH} -Qunused-arguments
#  Turn on call() support for assertion checking
#CFLAGS += -DDEBUG
#  Optimization level needs to match whatever the kernel is compiled with.

ifdef INC_KERNEL
CFLAGS += $(KERNEL_INCLUDES)
ASFLAGS += $(KERNEL_INCLUDES)
endif

ifdef DEBUG
CFLAGS += -DDEBUG
endif

CFLAGS += $(EXTRA_CFLAGS)

################################################################################
#  Convenience shortcuts
################################################################################

ifdef SUBDIRS

################################################################################
#  Recursive subdirectory traversal
################################################################################

#SUBDIR_MAKE=+for SUBDIR in ${SUBDIRS}; do\
#	$(MAKE) -C $$SUBDIR $(MAKECMDGOALS) TEST=$$SUBDIR; TSTAT=$$?; \
#        if [ $$TSTAT -ne 0 ]; then STAT=$$TSTAT; fi; \
#	done; exit $$STAT

#SUBDIR_TARGETS=clean all

#${SUBDIR_TARGETS}:
#	${SUBDIR_MAKE}

#  Uh...  don't run this unless all the tests are run for now.
cov.txt:
	find ./kernel ./libs -name "cov.txt" | $(PYTHON) ${H2DIR}/scripts/merge_cov.py --offset_pc > $@

cov.rpt: cov.txt
	${H2DIR}/scripts/cov_rpt_tool > $@

#  every "subdir" needs to have a results.txt in it for this to run properly.
#  if no results.txt, FAIL
#  if results.txt is empty, FAIL
#  
#	      grep -A 1 FAIL $$SUBDIR/test.log >> report.html; \
#	      echo FAIL:  no pass signature >> report.html;\

report.html:
	@echo "<html><body><table>" > report.html;\
	for SUBDIR in ${SUBDIRS}; do\
	   echo "<tr><td> $$SUBDIR</td>" >> report.html;\
	   if [ ! -s $$SUBDIR/results.txt ]; then\
	      echo '<td><font style="background-color: red;">' >> report.html; \
	      echo 'Missing results.txt, that should not be!' >> report.html; \
	      echo '</font></td>' >> report.html; \
	   else\
	      grep "TEST PASSED" $$SUBDIR/results.txt > /dev/null; \
	      if [ $$? -eq 0 ]; then \
	         echo '<td>' >> report.html; \
		 cat $$SUBDIR/results.txt >> report.html; \
		 echo '</td>' >> report.html; \
	      else \
	         echo '<td><font style="background-color: red;">' >> report.html; \
		 cat $$SUBDIR/results.txt >> report.html; \
		 echo '</font></td>' >> report.html; \
	      fi; \
	   fi; \
	   cat $$SUBDIR/make.log >> make.log;\
	done;\
	echo "</table></body></html>" >> report.html;

qurt_report.html: report.html
	mv report.html qurt_report.html

h2_report.html: report.html
	mv report.html h2_report.html

.PHONY: check

check-fail:
	@for SUBDIR in ${SUBDIRS}; do\
	   echo -n "$$SUBDIR: "; \
	   if [ ! -s $$SUBDIR/results.txt ]; then\
	      echo FAIL - Empty/No results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "ERROR" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - ERROR detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "FAIL" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - FAIL detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "status 0xaaafa7a1" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - status 0xaaafa7a1 detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "TEST PASSED" $$SUBDIR/results.txt;\
	   if [ $$? -ne 0 ]; then\
	      echo FAIL - No PASS detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   echo; \
	done

check:
	@for SUBDIR in ${SUBDIRS}; do\
	   echo -n "$$SUBDIR: "; \
	   if [ ! -s $$SUBDIR/results.txt ]; then\
	      echo FAIL - Empty/No results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   grep "ERROR" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - ERROR detected in results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   grep "FAIL" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - FAIL detected in results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   grep "status 0xaaafa7a1" $$SUBDIR/results.txt;\
	   if [ $$? -eq 0 ]; then\
	      echo FAIL - status 0xaaafa7a1 detected in results.txt; \
	      echo; \
	      exit 1;\
	   fi;\
	   grep "TEST PASSED" $$SUBDIR/results.txt;\
	   if [ $$? -ne 0 ]; then\
	      echo FAIL - No PASS detected in results.txt; \
	      echo; \
	      continue;\
	   fi;\
	   echo; \
	done


else

DUMP:= $(patsubst %.elf,%.objdump,$(EXEC))

################################################################################
#  These are for actual terminal directories
################################################################################
%.objdump: %.elf
	${OBJDUMP} -d ${@:.objdump=.elf} ${BOOTER} > $@; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\ndisassm fail"|tee test.log; fi

ifdef PYTHON_GENERATOR_SCRIPT
${PYTHON_GENERATED_FILES}: ${PYTHON_GENERATOR_SCRIPT}
	${PYTHON} $<; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; fi
endif

%.o: %.c ${PYTHON_GENERATED_FILES}
	${CC} ${CFLAGS} -c -o $@ $<; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; fi

%.o: %.S ${PYTHON_GENERATED_FILES}
	${CC} ${ASFLAGS} -c -o $@ $<; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; fi

${EXEC}: ${OBJS} constants
# How's this for an ugly hack?
	${CC} -o $@ ${OBJS} ${LDFLAGS} 2>&1 | perl -pe 's/.*Symbol.*__h2_handle_errors_hook__.*is defined in both linker script and input file.*//'; \
	CODE=$${PIPESTATUS[0]}; \
	if [ "$$CODE" -ne 0 ]; then echo -e "FAIL ${TEST}\nbuild fail"|tee test.log; fi

ignore_fns: ${OBJS}
	${H2DIR}/scripts/gen_ignore_fns.pl ${OBJS} > $@

# each test has a max of 60 seconds!
test.log: ${EXEC}
	echo PKW_VERSIONS $(PKW_VERSIONS) >> $@
	echo PKW_arch $(PKW_arch) >> $@
	echo PKW_hexagon-tools $(PKW_hexagon-tools) >> $@
	ulimit -t ${ULIMIT} && ${RUN} ${SIMF} --profile -- ${BOOTER} ${BOOTER_ARGS} ${EXEC} | tee -a $@; \
	CODE=$${PIPESTATUS[0]}; \
	echo exit status == $$CODE; \
	if [ "$$CODE" -eq 137 ]; then \
	   echo -e "\nERROR: ${TEST}: probably ulimit" >> $@; \
	fi; \
	if [ "$$QURT_TEST" != "" ]; then \
		if [ "$$CODE" -ne 0 ]; then \
			echo "FAIL" >> $@; \
		else \
			echo "TEST PASSED" >> $@; \
		fi; \
	fi;
	$(POST_RUN)

# Coverage stuff -- single testcase

.PHONY: try_gmon_out

try_gmon_out: test.log
	find . -maxdepth 1 | egrep -q 'gmon\.t_'; \
	if [ $$? -eq 0 ]; then \
		${GMON_MERGE} -o gmon.out gmon.t_*; \
	fi

COVFILE=cov.txt
GMON_FILES=gmon.* gmon-*

${COVFILE}: ${DUMP} try_gmon_out ignore_fns
	if [ -f gmon.out ]; then \
		${COV} -F -d ${DUMP} -o cov.txt gmon.out; \
		if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\ncoverage fail"; exit 1; fi; \
	else \
		find . -maxdepth 1 -name 'gmon-0x????????.out' | perl -ne 'chomp; $$f = $$_; s/^\.\/gmon-//; s/.out$$//; system("$(COV) -F -d test.objdump -o cov-$$_.txt $$f")'; \
		find . -name 'cov-0x*.txt' | $(PYTHON) ${H2DIR}/scripts/merge_cov.py --dir $(H2DIR) > $@; \
	fi; \
	if [ $$? -ne 0 ]; then echo -e "FAIL ${TEST}\ncoverage fail"; exit 1; fi

CLEANUP=${PYTHON_GENERATED_FILES} ${OBJS} ${EXEC} ${COVFILE} cov-*.txt ${GMON_FILES} ${DUMP} make.log test.log results.txt h2
CLEANUP += stats.txt stats_help.txt ihist.txt prof.txt ignore_fns pmu_statsfile.txt pmu_stats.txt

clean:
	rm -rf ${CLEANUP}

#  Pretty much a binary yes/no if the test passed or failed.
results.txt: test.log
	@grep -A 1 "ERROR" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 1; fi; \
	grep -A 1 "FAIL" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 1; fi; \
	grep -A 1 "status 0xaaafa7a1" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 1; fi; \
	grep "TEST PASSED" test.log > $@; \
	if [ $$? -eq 0 ]; then exit 0; fi; \
	if [ ! -s test.log ]; then \
	  echo "FAIL - Test log empty" > $@; \
	  exit 1; \
	fi; \
	echo "NO PASS/FAIL/ERROR in log" > $@; \
	exit 1;

all: results.txt ${COVFILE}
tst: results.txt


endif

endif
